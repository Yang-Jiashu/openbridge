{
  "name": "remote-commander-opencode",
  "version": "1.0.0",
  "description": "Remote PC Controller powered by OpenCode",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "pkg . -t node18-win-x64 --out-path dist"
  },
  "dependencies": {
    "@opencode-ai/sdk": "latest",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ]
  }
}
