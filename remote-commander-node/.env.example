# ========================================
# OpenBridge Server Configuration
# ========================================

# Server Port (default: 8000)
PORT=8000

# API Security Key (CHANGE THIS!)
# This key is required for all API requests (X-API-Key header)
API_KEY=your-secure-api-key-here

# CORS Origins (comma-separated)
# Use "*" to allow all origins (not recommended for production)
# Or specify domains: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=*

# ========================================
# OpenCode Integration (Optional)
# ========================================

# OpenCode API URL
OPENCODE_API_URL=http://localhost:12345

# OpenCode API Key (if required)
OPENCODE_API_KEY=

# Mock Mode (true = use mock responses, false = connect to real OpenCode)
MOCK_MODE=true

# ========================================
# Internet Access Guide
# ========================================
#
# Option 1: Local Network (Default)
# - Server binds to 0.0.0.0 (all interfaces)
# - Access via http://YOUR_LOCAL_IP:8000
# - Works on same WiFi/LAN only
#
# Option 2: Ngrok (Free, Easy)
# 1. Install ngrok: https://ngrok.com/download
# 2. Run: ngrok http 8000
# 3. Use the https URL provided (e.g., https://abc123.ngrok-free.app)
# 4. Update your mobile app with this URL
#
# Option 3: Frp (Self-hosted)
# - Setup frp server on VPS
# - Run frp client on your PC
# - Get permanent domain
#
# Option 4: Cloudflare Tunnel
# 1. Install cloudflared
# 2. Run: cloudflared tunnel --url http://localhost:8000
# 3. Use the generated URL
#
# Option 5: VPS/Cloud Server (Production)
# - Deploy to AWS/Azure/GCP/阿里云
# - Use PM2: npm install -g pm2 && pm2 start server.js
# - Setup Nginx reverse proxy with SSL
# - Domain + HTTPS recommended
#
